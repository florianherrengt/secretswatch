PORT=3000
DOMAIN=localhost:3000
DOMAIN_NAME=yourdomain.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_password_here
SMTP_FROM=noreply@yourdomain.com
DEBUG_ENDPOINT=false
DATABASE_URL=postgresql://secrets_watch:secrets_watch@localhost:5432/secrets_watch
REDIS_URL=redis://localhost:6379
PRODUCT_HUNT_TOKEN=your_product_hunt_token_here
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_BILLING_PORTAL_CREATE_ATTEMPTS=2
BILLING_PORTAL_RATE_LIMIT_WINDOW_MS=60000
BILLING_PORTAL_RATE_LIMIT_MAX_REQUESTS=5
SCAN_RATE_LIMIT_WINDOW_MS=60000
SCAN_RATE_LIMIT_MAX_REQUESTS=10
SCAN_MAX_CONCURRENT_REQUESTS=20

ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=changeme
LEGAL_CONTACT_EMAIL=legal@yourdomain.com

# --- Parallel worktree isolation (docker-compose vars) ---------------------
# These are the single-source-of-truth ports/names docker-compose.yml reads.
# IMPORTANT: keep DATABASE_URL/REDIS_URL ports in sync with PG_PORT/REDIS_PORT.
# `make parallel-create BRANCH=...` generates a per-worktree .env from this
# file with isolated values (unique slot, ports, containers, db name, data
# dirs) so multiple branches can run simultaneously. The defaults below match
# DATABASE_URL/REDIS_URL above and must stay aligned.
PG_PORT=5432
REDIS_PORT=6379
PG_DB_NAME=secrets_watch
COMPOSE_PROJECT_NAME=secret-detector
PG_CONTAINER_NAME=secrets-watch-postgres
REDIS_CONTAINER_NAME=secrets-watch-redis
PG_DATA_PATH=postgres_data
REDIS_DATA_PATH=redis_data
APP_PORT=3000
