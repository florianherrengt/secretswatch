{
	"name": "secret-detector",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/server/app.ts",
		"build": "tsc",
		"start": "node dist/server/app.js",
		"prepare": "node scripts/install-hooks.mjs",
		"typecheck": "tsc --noEmit",
