		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "^3.1028.0",
		"@bull-board/api": "^6.21.0",
		"@bull-board/hono": "^6.21.0",
		"@hono/node-server": "^1.19.13",
		"bullmq": "^5.73.3",
		"dotenv": "^17.4.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.7.4",
		"ioredis": "^5.10.1",
		"pg": "^8.20.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@types/node": "^22.13.9",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.4"
