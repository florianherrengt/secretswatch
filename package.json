{
	"name": "secret-detector",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "run-s build:css dev:watch",
		"dev:watch": "tsx watch src/server/app.ts",
		"build": "run-s build:css build:ts build:copy-assets",
		"build:ts": "tsc",
		"build:copy-assets": "node scripts/copy-sandbox-demo-assets.mjs",
		"build:css": "tailwindcss -i ./src/views/styles/app.css -o ./assets/app.css --minify",
		"start": "node dist/server/app.js",
		"prepare": "node scripts/install-hooks.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/ tests/",
		"lint:design-system-enforcement": "eslint src/views --format json --max-warnings=0",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:serve": "run-s e2e:prepare build start",
		"e2e:prepare": "node scripts/prepare-e2e-db.mjs",
		"resetRateLimit": "node scripts/resetRateLimit.mjs",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,yaml,yml,md,css,html,scss}\"",
		"format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,yaml,yml,md,css,html,scss}\""
	},
	"dependencies": {
		"@bull-board/api": "^6.21.0",
		"@bull-board/hono": "^6.21.0",
		"@hono/node-server": "^1.19.13",
		"bullmq": "^5.73.3",
		"dotenv": "^17.4.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.7.4",
		"ioredis": "^5.10.1",
		"nodemailer": "^8.0.5",
		"pg": "^8.20.0",
		"rate-limiter-flexible": "^11.0.0",
		"stripe": "^22.0.2",
		"zod": "^3.24.2"
	},
	"license": "MIT-Commons-Clause",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/cli": "^4.2.2",
		"@types/node": "^22.19.17",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.3",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.4"
	}
}
