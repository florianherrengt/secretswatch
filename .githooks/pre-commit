#!/bin/sh

if [ -n "$(git rev-parse -q --verify MERGE_HEAD 2>/dev/null)" ]; then
	exit 0
fi

echo "Running lint..."
if ! npm run lint; then
	echo "ERROR: Lint failed. Fix lint issues before committing."
	exit 1
fi

echo "Running unit tests..."
if ! npm run test; then
	echo "ERROR: Unit tests failed. Fix tests before committing."
	exit 1
fi
